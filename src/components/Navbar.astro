---
interface Props {
  showCta?: boolean;
}
const { showCta = true } = Astro.props;
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-surface/80 backdrop-blur-lg border-b border-primary-100">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center">
      <img src="/Logo-tellio-red.png" alt="Tellio" class="h-8" />
    </a>

    <!-- Nav links (desktop) -->
    <div class="hidden md:flex items-center gap-8 text-sm font-medium text-text-muted">
      <a href="/#perche" class="hover:text-primary-700 transition-colors">Perch&eacute; usarla</a>
      <a href="/#come-funziona" class="hover:text-primary-700 transition-colors">Come funziona</a>
      <a href="/#vantaggi" class="hover:text-primary-700 transition-colors">Perch&eacute; sceglierci</a>
      <a href="/#faq" class="hover:text-primary-700 transition-colors">FAQ</a>
    </div>

    <!-- CTA -->
    <div class="flex items-center gap-3">
      {showCta && (
        <a
          href="/signup"
          class="inline-flex items-center px-4 py-2 sm:px-5 sm:py-2.5 text-xs sm:text-sm font-semibold text-white bg-primary-700 rounded-full hover:bg-primary-800 transition-colors shadow-sm"
        >
          Iscriviti
        </a>
      )}
      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 text-text-muted hover:text-primary-700 transition-colors"
        aria-label="Menu"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-primary-100 bg-surface/95 backdrop-blur-lg">
    <div class="px-4 py-4 space-y-3 text-sm font-medium text-text-muted">
      <a href="/#perche" class="block py-1 hover:text-primary-700 transition-colors">Perch&eacute; usarla</a>
      <a href="/#come-funziona" class="block py-1 hover:text-primary-700 transition-colors">Come funziona</a>
      <a href="/#vantaggi" class="block py-1 hover:text-primary-700 transition-colors">Perch&eacute; sceglierci</a>
      <a href="/#faq" class="block py-1 hover:text-primary-700 transition-colors">FAQ</a>
      {showCta && (
        <a href="/signup" class="block mt-2 text-center px-5 py-3 font-semibold text-white bg-primary-700 rounded-full hover:bg-primary-800 transition-colors shadow-sm">
          Iscriviti
        </a>
      )}
    </div>
  </div>
</nav>

<!-- Beta banner -->
<div class="fixed top-16 left-0 right-0 z-40 bg-primary-700 text-white text-center text-xs py-1.5 font-medium tracking-wide">
  Versione beta, in continuo miglioramento.
</div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
  // Close menu on link click
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => menu?.classList.add('hidden'));
  });
</script>
