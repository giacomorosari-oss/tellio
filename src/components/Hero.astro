---
---

<section class="relative min-h-[calc(100vh-4rem)] flex items-center justify-center bg-surface overflow-hidden">
  <!-- Raggi radiali -->
  <div class="absolute inset-0 flex items-center justify-center">
    <div class="hero-rays absolute w-[800px] h-[800px] sm:w-[1400px] sm:h-[1400px]"></div>
  </div>

  <!-- Fade radiale -->
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_25%,var(--color-surface)_70%)]"></div>

  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center py-20">
    <h1 class="text-3xl sm:text-5xl md:text-6xl font-extrabold tracking-tight text-text leading-tight">
      Trova un collega <span class="text-primary-700">in un attimo.</span>
    </h1>

    <p class="mt-5 sm:mt-6 text-base sm:text-lg md:text-xl text-text-muted max-w-2xl mx-auto leading-relaxed">
      Dimentica i gruppi caotici e le chiamate a vuoto. Tellio ti connette su WhatsApp con i colleghi che sono già in aula.
    </p>

    <!-- CTA -->
    <div class="mt-8 sm:mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="/signup"
        class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-white bg-primary-700 rounded-full hover:bg-primary-800 transition-all shadow-lg shadow-primary-700/25 hover:shadow-primary-700/40"
      >
        Iscriviti ora
      </a>
    </div>

    <p class="mt-4 text-xs sm:text-sm text-text-light">
      Lista d'attesa prioritaria per avvocati penalisti.
    </p>
  </div>
</section>

<style>
  .hero-rays {
    background: repeating-conic-gradient(
      from 0deg,
      var(--color-primary-200) 0deg 1deg,
      transparent 1deg 10deg
    );
    opacity: 0.15;
    mask-image: radial-gradient(circle, black 15%, transparent 65%);
    -webkit-mask-image: radial-gradient(circle, black 15%, transparent 65%);
  }
</style>
