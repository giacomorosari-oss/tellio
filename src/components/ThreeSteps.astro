---
const steps = [
  {
    number: "1",
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>`,
    label: "Tu",
    desc: "Mandi un messaggio WhatsApp"
  },
  {
    number: "2",
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>`,
    label: "Tellio",
    desc: "L'AI capisce e organizza"
  },
  {
    number: "3",
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
    label: "Risultato",
    desc: "Ricevi risposta immediata"
  }
];
---

<section class="py-14 sm:py-20 md:py-28 bg-surface">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="fade-in text-2xl sm:text-3xl md:text-4xl font-bold text-text">
      È davvero semplicissimo.
    </h2>
    <p class="fade-in mt-3 text-text-muted">Zero app. Zero complicazioni. Solo WhatsApp.</p>

    <div class="fade-in mt-10 sm:mt-14 flex flex-col sm:flex-row items-center justify-center gap-6 sm:gap-0">
      {steps.map((step, i) => (
        <>
          <div class="flex flex-col items-center text-center max-w-[200px]">
            <div class="relative">
              <div class="w-16 h-16 rounded-full bg-primary-700 text-white flex items-center justify-center shadow-lg shadow-primary-700/25">
                <Fragment set:html={step.icon} />
              </div>
              <span class="absolute -top-1 -right-1 w-6 h-6 rounded-full bg-white text-primary-700 text-xs font-bold flex items-center justify-center shadow-md border-2 border-primary-700">
                {step.number}
              </span>
            </div>
            <h3 class="mt-4 text-base font-bold text-text">{step.label}</h3>
            <p class="mt-1 text-sm text-text-muted">{step.desc}</p>
          </div>
          {i < steps.length - 1 && (
            <>
              <div class="hidden sm:flex items-center px-4 md:px-6 -mt-8">
                <svg class="w-8 h-8 text-primary-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
              </div>
              <div class="sm:hidden flex justify-center">
                <svg class="w-6 h-6 text-primary-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 11l5 5m0 0l5-5m-5 5V4" />
                </svg>
              </div>
            </>
          )}
        </>
      ))}
    </div>
  </div>
</section>
