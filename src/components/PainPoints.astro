---
const leftCards = [
  {
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>`,
    title: "L'imprevisto in agenda",
    desc: "Un'udienza sovrapposta, un'emergenza o una semplice dimenticanza."
  },
  {
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>`,
    title: "Il giro di telefonate",
    desc: "Chiami colleghi o scrivi su decine di gruppi WhatsApp, sperando che qualcuno legga e risponda in tempo."
  },
  {
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v2m0 4h.01M12 3l9.09 15.09a1 1 0 01-.87 1.41H3.78a1 1 0 01-.87-1.41L12 3z" /></svg>`,
    title: 'Il rischio del "vuoto"',
    desc: "L'ansia di non trovare nessuno disponibile e lasciare l'udienza scoperta o arrivare stressati in ritardo."
  }
];

const rightCards = [
  {
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
    title: "L'improduttività",
    desc: "Il tempo libero in Tribunale tra un'udienza e l'altra resta improduttivo."
  },
  {
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>`,
    title: "I colleghi che non sanno dove sei",
    desc: "Potrebbero aver bisogno di te ma non sanno che sei disponibile, e non hanno modo di saperlo."
  },
  {
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>`,
    title: "Nessuno ti contatta",
    desc: "Potresti collaborare o aiutare un collega. Ma nessuno ti cerca perché non sanno dove sei."
  }
];
---

<section id="perche" class="py-14 sm:py-20 md:py-28 bg-surface">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="fade-in text-center max-w-3xl mx-auto mb-10 sm:mb-14">
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-text">
        Il problema che ogni avvocato conosce.
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 sm:gap-8 fade-in-children">
      <!-- Colonna SX — Chi cerca -->
      <div class="bg-surface-card border border-primary-100/60 rounded-2xl p-6 sm:p-8 hover:shadow-xl hover:shadow-primary-200/20 transition-all duration-300">
        <span class="inline-block text-xs font-semibold uppercase tracking-wider text-primary-600 bg-primary-100 px-3 py-1 rounded-full mb-4">
          Chi cerca un sostituto
        </span>
        <h3 class="text-xl sm:text-2xl font-bold text-text mb-8">
          L'incubo della sostituzione last-minute.
        </h3>
        <div class="space-y-6">
          {leftCards.map((card, i) => (
            <div class="flex items-start gap-4">
              <div class="relative flex flex-col items-center">
                <div class="w-10 h-10 rounded-full bg-primary-700 text-white flex items-center justify-center shrink-0">
                  <Fragment set:html={card.icon} />
                </div>
                {i < leftCards.length - 1 && (
                  <div class="w-px h-6 bg-primary-200 mt-2"></div>
                )}
              </div>
              <div class="pt-1">
                <h4 class="text-sm font-bold text-text">{card.title}</h4>
                <p class="mt-1 text-sm text-text-muted leading-relaxed">{card.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Colonna DX — Chi è disponibile -->
      <div class="bg-primary-700 rounded-2xl p-6 sm:p-8 text-white shadow-xl shadow-primary-700/25 hover:shadow-2xl hover:shadow-primary-700/30 transition-all duration-300">
        <span class="inline-block text-xs font-semibold uppercase tracking-wider text-primary-200 bg-white/15 px-3 py-1 rounded-full mb-4">
          Chi è disponibile
        </span>
        <h3 class="text-xl sm:text-2xl font-bold mb-8">
          Sei in Tribunale e nessuno lo sa.
        </h3>
        <div class="space-y-6">
          {rightCards.map((card, i) => (
            <div class="flex items-start gap-4">
              <div class="relative flex flex-col items-center">
                <div class="w-10 h-10 rounded-full bg-white/20 text-white flex items-center justify-center shrink-0">
                  <Fragment set:html={card.icon} />
                </div>
                {i < rightCards.length - 1 && (
                  <div class="w-px h-6 bg-white/20 mt-2"></div>
                )}
              </div>
              <div class="pt-1">
                <h4 class="text-sm font-bold">{card.title}</h4>
                <p class="mt-1 text-sm text-primary-200 leading-relaxed">{card.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
